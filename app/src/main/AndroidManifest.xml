<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="MissingLeanbackLauncher,MissingLeanbackSupport">

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:banner="@mipmap/app_icon"
        android:icon="@mipmap/app_icon"
        android:installLocation="internalOnly"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:roundIcon="@mipmap/app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.Transparent"
        tools:ignore="ExtraText,MissingTvBanner"
        tools:targetApi="23">
        <activity
            android:name=".activities.AdvertLandWatch"
            android:exported="false" />
        <activity
            android:name=".activities.InfoActivity"
            android:exported="false" /> <!-- شاشة المعاينة -->
        <activity
            android:name=".activities.PreviewAds"
            android:exported="true" /> <!-- شاشة تسجيل الدخول، هي Main للموبايل وTV -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustPan">

            <!-- الموبايل -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Android TV -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity> <!-- شاشة عرض الإعلانات -->
        <activity
            android:name=".activities.AdvertWatching"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="true"
            />
        <activity
            android:name=".activities.SelectScreens"
            android:exported="true" />
    </application>

</manifest>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainConstLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <!-- Waiting / splash logo -->
    <ImageView
        android:id="@+id/waitingLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@mipmap/app_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad image -->
    <ImageView
        android:id="@+id/adImageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad video player -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/adPlayerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fill"
        app:use_controller="false" />

    <!-- ═══════════════════════════════════════════════
         WEATHER SLIDE — portrait
         ═══════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/weatherLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_weather_slide"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Metrics strip starts at 82% from top -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/h_metrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.82" />

        <!-- Location row: pin + city -->
        <ImageView
            android:id="@+id/loc_pin_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/baseline_location_pin_24"
            android:tint="@color/tvAccent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/weatherLoc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="20dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="London"
            android:textColor="@color/tvTextSecondary"
            android:textSize="@dimen/text_location"
            app:layout_constraintBottom_toBottomOf="@id/loc_pin_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/loc_pin_icon"
            app:layout_constraintTop_toTopOf="@id/loc_pin_icon" />

        <!-- Content chain: clock → icon → temp → condition -->
        <TextView
            android:id="@+id/timeNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:letterSpacing="-0.02"
            android:text="15:05"
            android:textColor="@color/tvTextPrimary"
            android:textSize="@dimen/text_time"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/currentWeatherImg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/loc_pin_icon"
            app:layout_constraintVertical_bias="0.4"
            app:layout_constraintVertical_chainStyle="packed" />

        <ImageView
            android:id="@+id/currentWeatherImg"
            android:layout_width="@dimen/weather_icon_size"
            android:layout_height="@dimen/weather_icon_size"
            android:layout_marginTop="4dp"
            app:layout_constraintBottom_toTopOf="@id/weatherTemp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/timeNow" />

        <TextView
            android:id="@+id/weatherTemp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:letterSpacing="-0.03"
            android:text="24°C"
            android:textColor="@color/tvTextPrimary"
            android:textSize="@dimen/text_temp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/currentStatus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/currentWeatherImg" />

        <TextView
            android:id="@+id/currentStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.10"
            android:text="PARTLY CLOUDY"
            android:textAllCaps="true"
            android:textColor="@color/tvTextSecondary"
            android:textSize="@dimen/text_condition"
            app:layout_constraintBottom_toTopOf="@id/h_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/weatherTemp" />

        <!-- Thin divider above metrics -->
        <View
            android:id="@+id/h_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/tvBorder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/h_metrics" />

        <!-- Metrics strip: Wind | Humidity | Feels Like -->
        <LinearLayout
            android:id="@+id/metrics_bar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/tvSurface"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/h_divider">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:alpha="0.75"
                    android:src="@drawable/wind"
                    android:tint="@color/tvTextSecondary" />

                <TextView
                    android:id="@+id/windW"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="32"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:letterSpacing="0.08"
                    android:text="km/h"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/metric_divider_height"
                android:background="@color/tvBorder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:alpha="0.75"
                    android:src="@drawable/humidity"
                    android:tint="@color/tvTextSecondary" />

                <TextView
                    android:id="@+id/hamudity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="60%"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:letterSpacing="0.08"
                    android:text="humidity"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/metric_divider_height"
                android:background="@color/tvBorder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:alpha="0.75"
                    android:src="@drawable/ic_thermostat"
                    android:tint="@color/tvTextSecondary" />

                <TextView
                    android:id="@+id/rain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="22°"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:letterSpacing="0.08"
                    android:text="feels like"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════
         NEWS SLIDE — portrait: image top 62%, text bottom 38%
         ═══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/newsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/tvBg"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Shimmer placeholder while loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/tvCard" />
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- News content -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/newsFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Split: image = top 62%, text = bottom 38% -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/news_split"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.62" />

            <!-- Full-bleed news image -->
            <ImageView
                android:id="@+id/news_img"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/background_port"
                app:layout_constraintBottom_toTopOf="@id/news_split"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Dark gradient at bottom of image for headline legibility -->
            <View
                android:id="@+id/header_background"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/gradient_news_overlay"
                app:layout_constraintBottom_toTopOf="@id/news_split"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_default="percent"
                app:layout_constraintHeight_percent="0.55"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/news_img"
                app:layout_constraintVertical_bias="1.0" />

            <!-- "NEWS" pill badge — top-left -->
            <TextView
                android:id="@+id/newsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/news_text_padding"
                android:layout_marginTop="@dimen/news_header_padding"
                android:background="@drawable/bg_news_badge"
                android:letterSpacing="0.15"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="NEWS"
                android:textColor="@color/tvTextPrimary"
                android:textSize="@dimen/text_news_label"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Headline over gradient -->
            <TextView
                android:id="@+id/main_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="start"
                android:lineSpacingMultiplier="1.1"
                android:maxLines="2"
                android:paddingStart="@dimen/news_text_padding"
                android:paddingEnd="@dimen/news_text_padding"
                android:paddingBottom="14dp"
                android:text="Breaking news headline"
                android:textColor="@color/tvTextPrimary"
                android:textSize="@dimen/text_news_headline"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/news_split"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Description panel -->
            <LinearLayout
                android:id="@+id/desc_panel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@color/tvSurface"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="@dimen/news_text_padding"
                android:paddingEnd="@dimen/news_text_padding"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/news_split">

                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/tvAccent" />

                <TextView
                    android:id="@+id/news_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:lineSpacingMultiplier="1.4"
                    android:maxLines="4"
                    android:text="News description text"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_news_desc" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <!-- QR code — bottom-right -->
    <ImageView
        android:id="@+id/qrCodeImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="5dp"
        android:adjustViewBounds="true"
        android:contentDescription="QR Code"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.95" />

    <!-- Debug Overlay - Shows current playback status (TODO: Remove before production) -->
    <TextView
        android:id="@+id/debugOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="#CC000000"
        android:padding="8dp"
        android:text="Debug: Initializing..."
        android:textColor="#00FF00"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Brand logo — bottom-left -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/final_logo"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Scrolling marquee text -->
    <TextView
        android:id="@+id/displayText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center"
        android:marqueeRepeatLimit="marquee_forever"
        android:scrollHorizontally="true"
        android:singleLine="true"
        android:text="Advert is Here"
        android:textColor="@color/tvTextPrimary"
        android:textSize="19sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/tvAccent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Updating..."
        android:textColor="@color/tvTextPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loadBar" />

</androidx.constraintlayout.widget.ConstraintLayout>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainConstLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Waiting / splash logo -->
    <ImageView
        android:id="@+id/waitingLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@mipmap/app_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad image -->
    <ImageView
        android:id="@+id/adImageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad video player -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/adPlayerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fill"
        app:use_controller="false" />

    <!-- ══════════════════════════════════════════════════════
         WEATHER SLIDE — professional dark vertical layout
         ══════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/weatherLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0C1120"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Guideline: metrics strip starts at 78% from top -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/h_metrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.78" />

        <!-- ── TOP: location row ── -->
        <LinearLayout
            android:id="@+id/location_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginStart="@dimen/slide_padding"
            android:layout_marginEnd="@dimen/slide_padding"
            android:layout_marginTop="@dimen/slide_padding"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="@dimen/weather_metric_icon_size"
                android:layout_height="@dimen/weather_metric_icon_size"
                android:src="@drawable/baseline_location_pin_24"
                android:alpha="0.6" />

            <TextView
                android:id="@+id/weatherLoc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="London"
                android:textColor="#7B8CA8"
                android:textSize="@dimen/text_location"
                android:textStyle="normal"
                android:letterSpacing="0.04"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- ── CENTER: giant clock ── -->
        <TextView
            android:id="@+id/timeNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15:05"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_time"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:letterSpacing="-0.02"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/location_row"
            app:layout_constraintBottom_toTopOf="@id/temp_block"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintVertical_bias="0.45" />

        <!-- ── MIDDLE: weather icon + temperature + condition ── -->
        <LinearLayout
            android:id="@+id/temp_block"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/timeNow"
            app:layout_constraintBottom_toTopOf="@id/h_divider">

            <ImageView
                android:id="@+id/currentWeatherImg"
                android:layout_width="@dimen/weather_icon_size"
                android:layout_height="@dimen/weather_icon_size"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/weatherTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24°C"
                    android:textColor="#F0F4FF"
                    android:textSize="@dimen/text_temp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/currentStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Partly Cloudy"
                    android:textColor="#5A6880"
                    android:textSize="@dimen/text_condition"
                    android:letterSpacing="0.04" />
            </LinearLayout>
        </LinearLayout>

        <!-- Thin divider above metrics -->
        <View
            android:id="@+id/h_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#1A2440"
            android:layout_marginStart="@dimen/slide_padding"
            android:layout_marginEnd="@dimen/slide_padding"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/h_metrics" />

        <!-- ── BOTTOM: metrics strip (wind | humidity | rain) ── -->
        <LinearLayout
            android:id="@+id/metrics_bar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#07101E"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/h_divider"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Wind -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:src="@drawable/wind"
                    android:alpha="0.5" />

                <TextView
                    android:id="@+id/windW"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="32"
                    android:textColor="#CDD5E0"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="km/h"
                    android:textColor="#3A4860"
                    android:textSize="@dimen/text_label"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/metric_divider_height"
                android:background="#1A2440" />

            <!-- Humidity -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:src="@drawable/humidity"
                    android:alpha="0.5" />

                <TextView
                    android:id="@+id/hamudity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="60"
                    android:textColor="#CDD5E0"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="humidity"
                    android:textColor="#3A4860"
                    android:textSize="@dimen/text_label"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/metric_divider_height"
                android:background="#1A2440" />

            <!-- Rain -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:src="@drawable/umbrella"
                    android:alpha="0.5" />

                <TextView
                    android:id="@+id/rain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="5"
                    android:textColor="#CDD5E0"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="mm rain"
                    android:textColor="#3A4860"
                    android:textSize="@dimen/text_label"
                    android:letterSpacing="0.08" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══════════════════════════════════════════════════════
         NEWS SLIDE — professional: full image + overlay headline
         ══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/newsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0C1120"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Shimmer -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#111825" />
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- News content -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/newsFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Guideline: image occupies top 62% -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/news_split"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.62" />

            <!-- Full news image — centerCrop fills the frame -->
            <ImageView
                android:id="@+id/news_img"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/background_port"
                app:layout_constraintBottom_toTopOf="@id/news_split"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Full gradient over the entire image (dark at bottom only) -->
            <View
                android:id="@+id/header_background"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/gradient_news_overlay"
                app:layout_constraintBottom_toTopOf="@id/news_split"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintHeight_percent="0.55"
                app:layout_constraintHeight_default="percent"
                app:layout_constraintTop_toTopOf="@id/news_img"
                app:layout_constraintVertical_bias="1.0" />

            <!-- "NEWS" category badge — top-left -->
            <TextView
                android:id="@+id/newsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/news_text_padding"
                android:layout_marginTop="@dimen/news_header_padding"
                android:background="@drawable/bg_news_badge"
                android:letterSpacing="0.15"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="NEWS"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_news_label"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Headline over gradient -->
            <TextView
                android:id="@+id/main_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="start"
                android:lineSpacingMultiplier="1.1"
                android:maxLines="2"
                android:paddingStart="@dimen/news_text_padding"
                android:paddingEnd="@dimen/news_text_padding"
                android:paddingBottom="12dp"
                android:text="Breaking news headline"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_news_headline"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/news_split"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Description panel -->
            <LinearLayout
                android:id="@+id/desc_panel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:background="#0C1120"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/news_text_padding"
                android:paddingEnd="@dimen/news_text_padding"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/news_split">

                <TextView
                    android:id="@+id/news_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:lineSpacingMultiplier="1.4"
                    android:maxLines="4"
                    android:text="News description text"
                    android:textColor="#8A9AB8"
                    android:textSize="@dimen/text_news_desc" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <!-- QR code (bottom-right) -->
    <ImageView
        android:id="@+id/qrCodeImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="5dp"
        android:adjustViewBounds="true"
        android:contentDescription="QR Code"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.95" />

    <!-- Brand logo (bottom-left) -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/final_logo"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Scrolling text -->
    <TextView
        android:id="@+id/displayText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center"
        android:marqueeRepeatLimit="marquee_forever"
        android:scrollHorizontally="true"
        android:singleLine="true"
        android:text="Advert is Here"
        android:textColor="@color/white"
        android:textSize="19sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Updating..."
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loadBar" />

</androidx.constraintlayout.widget.ConstraintLayout>

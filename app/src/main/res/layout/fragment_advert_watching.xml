<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainConstLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <!-- Waiting / splash logo — full-screen black backdrop, logo centred -->
    <ImageView
        android:id="@+id/waitingLogo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        android:padding="80dp"
        android:scaleType="fitCenter"
        android:src="@drawable/adjaba_logo_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad image -->
    <ImageView
        android:id="@+id/adImageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad video player -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/adPlayerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fill"
        app:use_controller="false" />

    <!-- ═══════════════════════════════════════════════
         WEATHER SLIDE — portrait: clock top, weather bottom, metrics strip
         ═══════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/weatherLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_weather_slide"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Metrics strip starts at 82% from top -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/h_metrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.82" />

        <!-- Clock / weather split at 47% -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/mid_split"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.47" />

        <!-- Header panel bottom at ~9% of screen height -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/header_bottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.09" />

        <!-- Solid black header panel — drawn first so pin/text render above it -->
        <View
            android:id="@+id/location_panel"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#000000"
            android:elevation="8dp"
            app:layout_constraintBottom_toTopOf="@id/location_bar_line"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 4dp Netflix Red anchor line -->
        <View
            android:id="@+id/location_bar_line"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="@color/tvAccent"
            android:elevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/header_bottom" />

        <!-- Location row: pin + city — vertically centred in header panel -->
        <ImageView
            android:id="@+id/loc_pin_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="24dp"
            android:src="@drawable/baseline_location_pin_24"
            android:tint="@color/tvAccent"
            android:elevation="8dp"
            app:layout_constraintBottom_toTopOf="@id/location_bar_line"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.5" />

        <TextView
            android:id="@+id/weatherLoc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="24dp"
            android:ellipsize="end"
            android:elevation="8dp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.08"
            android:maxLines="1"
            android:text="London"
            android:textColor="@color/tvTextSecondary"
            android:textSize="@dimen/text_location"
            app:layout_constraintBottom_toBottomOf="@id/loc_pin_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/loc_pin_icon"
            app:layout_constraintTop_toTopOf="@id/loc_pin_icon" />

        <!-- TOP HALF: clock + date, packed and vertically centred between header and mid_split -->
        <!-- ✨ ENHANCED: Premium clock typography with subtle animations -->
        <TextView
            android:id="@+id/timeNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:includeFontPadding="false"
            android:letterSpacing="0.05"
            android:text="15:05"
            android:textColor="@color/tvTextPrimary"
            android:textSize="@dimen/text_time"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/dateNow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/location_bar_line"
            app:layout_constraintVertical_bias="0.5"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Enhanced date styling: elegant secondary typography -->
        <TextView
            android:id="@+id/dateNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:letterSpacing="0.12"
            android:text="Thu, 15 May"
            android:textAllCaps="true"
            android:textColor="@color/tvTextSecondary"
            android:textSize="@dimen/text_date"
            app:layout_constraintBottom_toTopOf="@id/mid_split"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/timeNow" />

        <!-- BOTTOM HALF: red glow + weather icon + temp + condition -->
        <!-- Glow rendered first so icon draws on top of it -->
        <View
            android:id="@+id/icon_glow"
            android:layout_width="@dimen/weather_icon_glow_size"
            android:layout_height="@dimen/weather_icon_glow_size"
            android:alpha="0.55"
            android:background="@drawable/bg_icon_glow"
            app:layout_constraintBottom_toBottomOf="@id/currentWeatherImg"
            app:layout_constraintEnd_toEndOf="@id/currentWeatherImg"
            app:layout_constraintStart_toStartOf="@id/currentWeatherImg"
            app:layout_constraintTop_toTopOf="@id/currentWeatherImg" />

        <ImageView
            android:id="@+id/currentWeatherImg"
            android:layout_width="@dimen/weather_icon_size"
            android:layout_height="@dimen/weather_icon_size"
            app:layout_constraintBottom_toTopOf="@id/weatherTemp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mid_split"
            app:layout_constraintVertical_bias="0.3"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- ✨ ENHANCED: Premium temperature display -->
        <TextView
            android:id="@+id/weatherTemp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:includeFontPadding="false"
            android:letterSpacing="-0.01"
            android:text="24°C"
            android:textColor="@color/tvTextPrimary"
            android:textSize="@dimen/text_temp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/currentStatus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/currentWeatherImg" />

        <!-- ✨ ENHANCED: Elegant weather condition text -->
        <TextView
            android:id="@+id/currentStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.08"
            android:text="PARTLY CLOUDY"
            android:textAllCaps="true"
            android:textColor="@color/tvTextSecondary"
            android:textSize="@dimen/text_condition"
            app:layout_constraintBottom_toTopOf="@id/h_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/weatherTemp" />

        <!-- Thin divider above metrics -->
        <View
            android:id="@+id/h_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/tvBorder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/h_metrics" />

        <!-- Metrics strip: Wind | Humidity | Feels Like -->
        <LinearLayout
            android:id="@+id/metrics_bar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/tvSurface"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/h_divider">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:alpha="0.80"
                    android:src="@drawable/ic_wind"
                    android:tint="@color/tvTextSecondary" />

                <TextView
                    android:id="@+id/windW"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black"
                    android:text="32"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.05"
                    android:text="km/h"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/metric_divider_height"
                android:background="@color/tvBorder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:alpha="0.80"
                    android:src="@drawable/ic_humidity"
                    android:tint="@color/tvTextSecondary" />

                <TextView
                    android:id="@+id/hamudity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black"
                    android:text="60%"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.05"
                    android:text="humidity"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="@dimen/metric_divider_height"
                android:background="@color/tvBorder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:alpha="0.80"
                    android:src="@drawable/ic_thermostat"
                    android:tint="@color/tvTextSecondary" />

                <TextView
                    android:id="@+id/rain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black"
                    android:text="22°"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_metrics"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.05"
                    android:text="feels like"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════
         NEWS SLIDE (REFACTORED) — Modern cinematic vertical stack:
         TOP:    Hero image 45-50% + dark gradient overlay + Ken Burns zoom
         MIDDLE: Large bold headline (white, centered, 2-3 lines)
         BOTTOM: Description text (light gray, 3-5 lines)
         Background: Pure black (#000000)
         Accent: Netflix red (#E50914)
         ═══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/newsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Shimmer placeholder while loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1a1a1a" />
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- News content: vertical stack layout -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/newsFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000">

            <!-- HERO IMAGE SECTION (45% of screen height) -->
            <!-- Hero image guideline: top section ends at 45% -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/hero_section_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.45" />

            <!-- Full-bleed hero image with edge-to-edge coverage -->
            <ImageView
                android:id="@+id/news_img"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:contentDescription="News hero image"
                android:src="@mipmap/background_port"
                app:layout_constraintBottom_toTopOf="@id/hero_section_end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Dark cinematic gradient overlay at bottom of hero image for text readability -->
            <View
                android:id="@+id/header_background"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/gradient_news_overlay"
                android:elevation="2dp"
                app:layout_constraintBottom_toTopOf="@id/hero_section_end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_default="percent"
                app:layout_constraintHeight_percent="0.35"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="1.0" />

            <!-- NEWS label badge — top-left corner of hero image -->
            <TextView
                android:id="@+id/newsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_news_badge"
                android:letterSpacing="0.15"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="NEWS"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_news_label"
                android:textStyle="bold"
                android:elevation="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- HEADLINE SECTION (10-15% of screen) — below hero image -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/headline_section_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.60" />

            <!-- Headline: Large, bold, white, centered, 2-3 lines max -->
            <!-- Safe area padding: ~4vh horizontal = ~40dp on typical portrait -->
            <TextView
                android:id="@+id/main_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:maxLines="3"
                android:text="Breaking news headline"
                android:textColor="#FFFFFF"
                android:textSize="42sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/headline_section_end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/hero_section_end" />

            <!-- DESCRIPTION SECTION (remaining space ~25-30%) -->
            <!-- Container for description with proper spacing -->
            <LinearLayout
                android:id="@+id/desc_panel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#000000"
                android:gravity="top|center_horizontal"
                android:orientation="vertical"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:paddingTop="20dp"
                android:paddingBottom="40dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/headline_section_end">

                <!-- Subtle Netflix red accent line above description -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="4dp"
                    android:layout_marginBottom="20dp"
                    android:background="@color/tvAccent" />

                <!-- Summary/Description text: light gray, 3-5 lines, excellent readability -->
                <TextView
                    android:id="@+id/news_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"
                    android:maxLines="5"
                    android:text="News summary and description text goes here"
                    android:textColor="#B3B3B3"
                    android:textSize="18sp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <!-- QR code — bottom-right -->
    <ImageView
        android:id="@+id/qrCodeImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="5dp"
        android:adjustViewBounds="true"
        android:contentDescription="QR Code"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.95" />

    <!-- Debug Overlay - Shows current playback status (TODO: Remove before production) -->
    <TextView
        android:id="@+id/debugOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="#CC000000"
        android:padding="8dp"
        android:text="Debug: Initializing..."
        android:textColor="#00FF00"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Brand logo — bottom-left -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/final_logo"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Scrolling marquee text -->
    <TextView
        android:id="@+id/displayText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center"
        android:marqueeRepeatLimit="marquee_forever"
        android:scrollHorizontally="true"
        android:singleLine="true"
        android:text="Advert is Here"
        android:textColor="@color/tvTextPrimary"
        android:textSize="19sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/tvAccent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Updating..."
        android:textColor="@color/tvTextPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loadBar" />

</androidx.constraintlayout.widget.ConstraintLayout>

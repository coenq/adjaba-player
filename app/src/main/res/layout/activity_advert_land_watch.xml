<?xml version="1.0" encoding="utf-8"?>
<!--
    Forced-portrait mode: device hardware = landscape, TV physically mounted = portrait.
    Each half of the weather/news LinearLayout is rotated -90° so content reads upright
    for a viewer standing in front of the portrait-mounted TV.
    Left half  → appears as TOP panel on portrait TV.
    Right half → appears as BOTTOM panel on portrait TV.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainConstLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <!-- Waiting / splash logo — full-screen black backdrop, -90° keeps logo upright on portrait-mounted TV -->
    <ImageView
        android:id="@+id/waitingLogo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        android:padding="80dp"
        android:rotation="-90"
        android:scaleType="fitCenter"
        android:src="@drawable/adjaba_logo_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad image -->
    <ImageView
        android:id="@+id/adImageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:rotation="180"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad video player -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/adPlayerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:rotation="180"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/adImageView"
        app:layout_constraintEnd_toEndOf="@id/adImageView"
        app:layout_constraintStart_toStartOf="@id/adImageView"
        app:layout_constraintTop_toTopOf="@id/adImageView"
        app:resize_mode="fill"
        app:surface_type="texture_view"
        app:use_controller="false" />

    <!-- ═══════════════════════════════════════════════════════
         WEATHER SLIDE — forced portrait
         LinearLayout required by Java (AdvertLandWatch casts it).
         Left half  → top panel on portrait TV  (location + clock)
         Right half → bottom panel on portrait TV (icon + temp + condition + metrics)
         Each half rotated -90° to read upright on portrait-mounted TV.
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/weatherLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_weather_slide"
        android:clipChildren="false"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- LEFT HALF → top panel on portrait TV: location + giant clock -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipChildren="false"
            android:gravity="center"
            android:orientation="vertical"
            android:rotation="-90">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/baseline_location_pin_24"
                    android:tint="@color/tvAccent" />

                <TextView
                    android:id="@+id/weatherLoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:text="London"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_location" />
            </LinearLayout>

            <TextView
                android:id="@+id/timeNow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:includeFontPadding="false"
                android:letterSpacing="0.01"
                android:text="15:05"
                android:textColor="@color/tvTextPrimary"
                android:textSize="@dimen/text_time" />

            <TextView
                android:id="@+id/dateNow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="0.18"
                android:text="Thu, 15 May"
                android:textAllCaps="true"
                android:textColor="@color/tvTextSecondary"
                android:textSize="@dimen/text_date" />
        </LinearLayout>

        <!-- 4dp Netflix Red anchor line — appears as horizontal separator between top/bottom panels on portrait TV -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/tvAccent"
            android:elevation="8dp" />

        <!-- RIGHT HALF → bottom panel on portrait TV: icon + temp + condition + metrics -->
        <!--
            The outer LinearLayout is rotated -90° so its vertical axis maps to the
            horizontal axis visible to the viewer on the physical portrait TV.
            The metrics container must be orientation="vertical" here so that after
            the outer -90° rotation the three metrics appear SIDE-BY-SIDE (left→right)
            on the physical portrait TV rather than stacked in a column.
        -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/tvSurface"
            android:clipChildren="false"
            android:gravity="center"
            android:orientation="vertical"
            android:rotation="-90">

            <ImageView
                android:id="@+id/currentWeatherImg"
                android:layout_width="@dimen/weather_icon_size"
                android:layout_height="@dimen/weather_icon_size" />

            <TextView
                android:id="@+id/weatherTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:includeFontPadding="false"
                android:letterSpacing="-0.02"
                android:text="24°C"
                android:textColor="@color/tvTextPrimary"
                android:textSize="@dimen/text_temp" />

            <TextView
                android:id="@+id/currentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.20"
                android:text="PARTLY CLOUDY"
                android:textAllCaps="true"
                android:textColor="@color/tvTextSecondary"
                android:textSize="@dimen/text_condition" />

            <!-- Horizontal divider (appears vertical after outer -90° rotation) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@color/tvBorder" />

            <!--
                Metrics: orientation="vertical" so that after the outer -90° rotation
                the three items appear side-by-side horizontally on the physical portrait TV.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Wind -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <ImageView
                        android:layout_width="@dimen/weather_metric_icon_size"
                        android:layout_height="@dimen/weather_metric_icon_size"
                        android:alpha="0.80"
                        android:src="@drawable/ic_wind"
                        android:tint="@color/tvTextSecondary" />

                    <TextView
                        android:id="@+id/windW"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="32"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="@dimen/text_metrics" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="sans-serif-light"
                        android:text="km/h"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="@dimen/text_label" />
                </LinearLayout>

                <View
                    android:layout_width="@dimen/metric_divider_height"
                    android:layout_height="1dp"
                    android:background="@color/tvBorder" />

                <!-- Humidity -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <ImageView
                        android:layout_width="@dimen/weather_metric_icon_size"
                        android:layout_height="@dimen/weather_metric_icon_size"
                        android:alpha="0.80"
                        android:src="@drawable/ic_humidity"
                        android:tint="@color/tvTextSecondary" />

                    <TextView
                        android:id="@+id/hamudity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="60%"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="@dimen/text_metrics" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="sans-serif-light"
                        android:text="humidity"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="@dimen/text_label" />
                </LinearLayout>

                <View
                    android:layout_width="@dimen/metric_divider_height"
                    android:layout_height="1dp"
                    android:background="@color/tvBorder" />

                <!-- Feels Like -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <ImageView
                        android:layout_width="@dimen/weather_metric_icon_size"
                        android:layout_height="@dimen/weather_metric_icon_size"
                        android:alpha="0.80"
                        android:src="@drawable/ic_thermostat"
                        android:tint="@color/tvTextSecondary" />

                    <TextView
                        android:id="@+id/rain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="22°"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="@dimen/text_metrics" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="sans-serif-light"
                        android:text="feels like"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="@dimen/text_label" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         NEWS SLIDE — forced portrait
         LinearLayout required by Java.
         Left half: image + NEWS badge (→ top panel on portrait TV)
         Right half: headline + description (→ bottom panel)
         NOTE: uses main_headerF / news_detailsF (not main_header / news_details)
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/newsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/tvBg"
        android:clipChildren="false"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Shimmer (zero-weight, hidden when content loads) -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0"
            android:visibility="gone">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/tvCard" />
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- LEFT HALF → top panel on portrait TV: full-bleed image + badge -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipChildren="false">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:rotation="-90">

                <ImageView
                    android:id="@+id/news_img"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/background_port"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Gradient at bottom 50% of image -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/gradient_news_overlay"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_default="percent"
                    app:layout_constraintHeight_percent="0.50"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="1.0" />

                <!-- "NEWS" badge — top-left -->
                <TextView
                    android:id="@+id/newsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_news_badge"
                    android:letterSpacing="0.12"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="NEWS"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_news_label"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>

        <!-- RIGHT HALF → bottom panel on portrait TV: headline + description -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/newsFrame"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/tvSurface"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="@dimen/news_text_padding"
                android:rotation="-90">

                <!-- Red accent bar -->
                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/tvAccent" />

                <!-- Headline -->
                <TextView
                    android:id="@+id/main_headerF"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:lineSpacingMultiplier="1.15"
                    android:maxLines="3"
                    android:paddingBottom="12dp"
                    android:text="Breaking news headline"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_news_headline"
                    android:textStyle="bold" />

                <!-- Thin separator -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/tvDivider" />

                <!-- Description -->
                <TextView
                    android:id="@+id/news_detailsF"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:lineSpacingMultiplier="1.3"
                    android:maxLines="5"
                    android:text="News description goes here"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_news_desc" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- QR code -->
    <ImageView
        android:id="@+id/qrCodeImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="5dp"
        android:adjustViewBounds="true"
        android:contentDescription="QR Code"
        android:scaleType="fitCenter"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.95" />

    <!-- Debug Overlay - Shows playback status (TODO: Remove before production) -->
    <TextView
        android:id="@+id/debugOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="#CC000000"
        android:padding="8dp"
        android:rotation="-90"
        android:text="Debug: Initializing..."
        android:textColor="#00FF00"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Brand logo — bottom corner, -90° keeps it upright on portrait-mounted TV -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:rotation="-90"
        android:src="@drawable/final_logo"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrolling display text -->
    <TextView
        android:id="@+id/displayText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="center"
        android:maxLines="3"
        android:rotation="-90"
        android:text="Advert is Here"
        android:textColor="@color/tvTextPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:translationX="-10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/tvAccent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Updating..."
        android:textColor="@color/tvTextPrimary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loadBar" />

</androidx.constraintlayout.widget.ConstraintLayout>

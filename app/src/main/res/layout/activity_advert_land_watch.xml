<?xml version="1.0" encoding="utf-8"?>
<!--
    Forced-portrait mode: device hardware = landscape, TV physically mounted = portrait.
    Each half of the weather/news LinearLayout is rotated -90° so content reads upright
    for a viewer standing in front of the portrait-mounted TV.
    Left half  → appears as TOP panel on portrait TV.
    Right half → appears as BOTTOM panel on portrait TV.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainConstLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <!-- Waiting logo (rotated to match physical portrait orientation) -->
    <ImageView
        android:id="@+id/waitingLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:rotation="-90"
        android:src="@mipmap/app_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad image -->
    <ImageView
        android:id="@+id/adImageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:rotation="180"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ad video player -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/adPlayerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:rotation="180"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/adImageView"
        app:layout_constraintEnd_toEndOf="@id/adImageView"
        app:layout_constraintStart_toStartOf="@id/adImageView"
        app:layout_constraintTop_toTopOf="@id/adImageView"
        app:resize_mode="fill"
        app:surface_type="texture_view"
        app:use_controller="false" />

    <!-- ═══════════════════════════════════════════════════════
         WEATHER SLIDE — forced portrait
         LinearLayout required by Java (AdvertLandWatch casts it).
         Two halves: left = clock panel (→ top of portrait TV)
                     right = temp + metrics (→ bottom of portrait TV)
         Each half's content rotated -90° to read upright on portrait TV.
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/weatherLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/tvBg"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- LEFT HALF → top panel on portrait TV -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:rotation="-90">

            <!-- Location row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size"
                    android:src="@drawable/baseline_location_pin_24"
                    android:tint="@color/tvAccent" />

                <TextView
                    android:id="@+id/weatherLoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="London"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_location"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Giant clock -->
            <TextView
                android:id="@+id/timeNow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:letterSpacing="-0.02"
                android:text="15:05"
                android:textColor="@color/tvTextPrimary"
                android:textSize="@dimen/text_time"
                android:textStyle="bold" />

            <!-- Condition text -->
            <TextView
                android:id="@+id/currentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.04"
                android:text="Partly Cloudy"
                android:textColor="@color/tvTextSecondary"
                android:textSize="@dimen/text_condition" />
        </LinearLayout>

        <!-- RIGHT HALF → bottom panel on portrait TV -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/tvSurface"
            android:gravity="center"
            android:orientation="vertical"
            android:rotation="-90">

            <!-- Icon + temperature row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/currentWeatherImg"
                    android:layout_width="@dimen/weather_icon_size"
                    android:layout_height="@dimen/weather_icon_size"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/weatherTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="24°C"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_temp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Red accent divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@color/tvAccent" />

            <!-- Metrics row: Wind | Humidity | Rain -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Wind -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/weather_metric_icon_size"
                        android:layout_height="@dimen/weather_metric_icon_size"
                        android:alpha="0.7"
                        android:src="@drawable/storm"
                        android:tint="@color/tvTextSecondary" />

                    <TextView
                        android:id="@+id/windW"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="32"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="@dimen/text_metrics"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km/h"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="@dimen/text_label" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="@dimen/metric_divider_height"
                    android:background="@color/tvDivider" />

                <!-- Humidity -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/weather_metric_icon_size"
                        android:layout_height="@dimen/weather_metric_icon_size"
                        android:alpha="0.7"
                        android:src="@drawable/humidity"
                        android:tint="@color/tvTextSecondary" />

                    <TextView
                        android:id="@+id/hamudity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="60"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="@dimen/text_metrics"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="%"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="@dimen/text_label" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="@dimen/metric_divider_height"
                    android:background="@color/tvDivider" />

                <!-- Rain -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/weather_metric_icon_size"
                        android:layout_height="@dimen/weather_metric_icon_size"
                        android:alpha="0.7"
                        android:src="@drawable/rainy"
                        android:tint="@color/tvTextSecondary" />

                    <TextView
                        android:id="@+id/rain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="5"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="@dimen/text_metrics"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="mm"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="@dimen/text_label" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         NEWS SLIDE — forced portrait
         LinearLayout required by Java.
         Left half: image + NEWS badge (→ top panel on portrait TV)
         Right half: headline + description (→ bottom panel)
         NOTE: uses main_headerF / news_detailsF (not main_header / news_details)
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/newsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/tvBg"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Shimmer (zero-weight, hidden when content loads) -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0"
            android:visibility="gone">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/tvCard" />
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- LEFT HALF → top panel: full-bleed image + badge -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:rotation="-90">

                <ImageView
                    android:id="@+id/news_img"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/background_port"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Gradient at bottom 50% of image -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/gradient_news_overlay"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_default="percent"
                    app:layout_constraintHeight_percent="0.50"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="1.0" />

                <!-- "NEWS" badge — top-left -->
                <TextView
                    android:id="@+id/newsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_news_badge"
                    android:letterSpacing="0.12"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="NEWS"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_news_label"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>

        <!-- RIGHT HALF → bottom panel: headline + description -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/newsFrame"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/tvSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="@dimen/news_text_padding"
                android:rotation="-90">

                <!-- Red accent bar -->
                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/tvAccent" />

                <!-- Headline -->
                <TextView
                    android:id="@+id/main_headerF"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:lineSpacingMultiplier="1.15"
                    android:maxLines="3"
                    android:paddingBottom="12dp"
                    android:text="Breaking news headline"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="@dimen/text_news_headline"
                    android:textStyle="bold" />

                <!-- Thin separator -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/tvDivider" />

                <!-- Description -->
                <TextView
                    android:id="@+id/news_detailsF"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:lineSpacingMultiplier="1.3"
                    android:maxLines="5"
                    android:text="News description goes here"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="@dimen/text_news_desc" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- QR code -->
    <ImageView
        android:id="@+id/qrCodeImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="5dp"
        android:adjustViewBounds="true"
        android:contentDescription="QR Code"
        android:scaleType="fitCenter"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.95" />

    <!-- Brand logo -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:rotation="-90"
        android:src="@drawable/final_logo"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrolling display text -->
    <TextView
        android:id="@+id/displayText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="center"
        android:maxLines="3"
        android:rotation="-90"
        android:text="Advert is Here"
        android:textColor="@color/tvTextPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:translationX="-10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/tvAccent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/progressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Updating..."
        android:textColor="@color/tvTextPrimary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loadBar" />

</androidx.constraintlayout.widget.ConstraintLayout>

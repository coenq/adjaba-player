<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="600dp"
            android:orientation="vertical"
            android:paddingStart="48dp"
            android:paddingEnd="48dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="8dp"
                android:scaleType="fitCenter"
                android:src="@mipmap/logo1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.12"
                android:text="DIGITAL SIGNAGE"
                android:textAllCaps="true"
                android:textColor="@color/tvTextSecondary"
                android:textSize="12sp" />

            <!-- Form card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tv_card"
                android:orientation="vertical"
                android:padding="36dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Welcome Back"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="32dp"
                    android:fontFamily="sans-serif-light"
                    android:text="Sign in to continue"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edt_email"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_tv_input"
                    android:fontFamily="sans-serif-light"
                    android:hint="Email address"
                    android:maxLines="1"
                    android:nextFocusDown="@+id/edt_password"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/tvTextPrimary"
                    android:textColorHint="@color/tvTextHint"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edt_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_tv_input"
                    android:fontFamily="sans-serif-light"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:nextFocusDown="@+id/rememberMeCheckBox"
                    android:nextFocusUp="@+id/edt_email"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/tvTextPrimary"
                    android:textColorHint="@color/tvTextHint"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/rememberMeCheckBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:nextFocusDown="@+id/btn_login"
                    android:nextFocusUp="@+id/edt_password"
                    android:text="Remember Me"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="14sp"
                    app:buttonTint="@color/tvAccent" />

                <Button
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_tv_button"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08"
                    android:nextFocusUp="@+id/rememberMeCheckBox"
                    android:text="SIGN IN"
                    android:textAllCaps="true"
                    android:textColor="@color/tvTextPrimary"
                    android:textSize="15sp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Loading overlay -->
    <ProgressBar
        android:id="@+id/progressBarLogin"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/tvAccent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

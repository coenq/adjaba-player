<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainSelectedScreenLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <!-- Waiting overlay -->
    <ImageView
        android:id="@+id/waitingLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@mipmap/app_icon"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/loadingBar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/tvAccent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Zero-size placeholder -->
    <ImageView
        android:id="@+id/loadingLogo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@mipmap/logo1"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:id="@+id/loginrootlayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Required by Java findViews() -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/topAppBar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@null" />

            <ImageView
                android:id="@+id/picture"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@mipmap/picture"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingTop="36dp"
                android:paddingBottom="40dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="28dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:scaleType="fitCenter"
                        android:src="@mipmap/logo1" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="Screen Configuration"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="22sp" />

                </LinearLayout>

                <!-- Orientation -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.06"
                    android:text="SCREEN ORIENTATION"
                    android:textAllCaps="true"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="11sp" />

                <Spinner
                    android:id="@+id/spinner1"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_tv_spinner"
                    android:entries="@array/screen_arrays"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:prompt="@string/screen_prompt"
                    android:theme="@style/ThemeOverlay.AppCompat.Dark" />

                <!-- Screen ID -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.06"
                    android:text="SCREEN ID"
                    android:textAllCaps="true"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="11sp" />

                <Spinner
                    android:id="@+id/spinnerID"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_tv_spinner"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:prompt="@string/screen_prompt"
                    android:theme="@style/ThemeOverlay.AppCompat.Dark" />

                <!-- Options -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_tv_card"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <CheckBox
                        android:id="@+id/rememberMeCh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Remember Me"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="15sp"
                        app:buttonTint="@color/tvAccent" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tvDivider" />

                    <CheckBox
                        android:id="@+id/text_display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Display Text"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="15sp"
                        app:buttonTint="@color/tvAccent" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tvDivider" />

                    <CheckBox
                        android:id="@+id/business_rule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Business Rules"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="15sp"
                        app:buttonTint="@color/tvAccent" />

                </LinearLayout>

                <!-- Refresh Interval -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.06"
                    android:text="DATA REFRESH INTERVAL"
                    android:textAllCaps="true"
                    android:textColor="@color/tvTextSecondary"
                    android:textSize="11sp" />

                <Spinner
                    android:id="@+id/spinner2"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/bg_tv_spinner"
                    android:entries="@array/interval_arrays"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:prompt="@string/interval_prompt"
                    android:theme="@style/ThemeOverlay.AppCompat.Dark" />

                <LinearLayout
                    android:id="@+id/bot_lay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/loginbtn"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_tv_button"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08"
                        android:text="PLAY"
                        android:textAllCaps="true"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/edit_screen"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_tv_button_secondary"
                        android:text="Edit"
                        android:textAllCaps="false"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="15sp"
                        android:visibility="gone" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/bot_lay2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ProgressBar
                        android:id="@+id/progressSignOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/tvAccent"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/logOut"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_tv_button_secondary"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.06"
                        android:text="SIGN OUT"
                        android:textAllCaps="true"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Zero-size in portrait: Java toggles visibility alongside nestedScrollView -->
    <LinearLayout
        android:id="@+id/logosLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ads_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/baseline_info_24" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/selectScreen"
    android:layout_height="match_parent"
    android:background="@mipmap/background_port"
    android:padding="15dp">


    <ImageView
        android:id="@+id/waitingLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:src="@mipmap/app_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <Button
        android:id="@+id/syncData"
        android:layout_width="130dp"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nestedScrollView"
        android:background="@drawable/btn_login_selector"
        android:elevation="10dp"
        android:gravity="center"
        android:drawableStart="@drawable/baseline_file_upload_24"
        android:padding="15dp"
        android:text="Sync"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        />

    <Button
        android:id="@+id/report_bt"
        android:layout_width="130dp"
        android:layout_height="60dp"
        android:background="@drawable/btn_login_selector"
        android:drawableStart="@drawable/baseline_menu_book_24"
        android:elevation="10dp"
        android:gravity="center"
        android:padding="15dp"
        android:text="Report"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nestedScrollView" />

    <ProgressBar
        android:id="@+id/loadingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nestedScrollView" />
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"

        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <RelativeLayout
            android:id="@+id/loginrootlayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <ImageView
                android:id="@+id/logo"
                android:layout_width="120dp"
                android:layout_height="60dp"
                android:src="@mipmap/logo1" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/topAppBar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:layout_toRightOf="@+id/logo"
                android:background="@null" />

            <!--app:menu="@menu/select_screen_top_menu"-->

            <ImageView
                android:id="@+id/picture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/logo"
                android:layout_centerHorizontal="true"
                android:scaleType="center"
                android:src="@mipmap/picture" />


            <RelativeLayout
                android:id="@+id/middle_lay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/picture"
                android:layout_centerHorizontal="true"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_width="500dp"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:orientation="vertical">


                    <LinearLayout
                        android:id="@+id/linearLayout2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/logo_lay"
                        android:elevation="10dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Choose Screen Orientation"
                            android:textColor="@color/black" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/list_bg"
                            android:padding="1dp">

                            <Spinner
                                android:id="@+id/spinner1"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:entries="@array/screen_arrays"
                                android:prompt="@string/screen_prompt" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Choose Screen ID"
                            android:textColor="@color/black" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/list_bg"

                            android:padding="1dp">

                            <Spinner
                                android:id="@+id/spinnerID"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:entries="@array/screen_arrays"
                                android:prompt="@string/screen_prompt" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">


                            <CheckBox
                                android:id="@+id/rememberMeCh"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:layout_weight="1"
                                android:text="Remember Me"

                                android:textColor="@color/black"
                                android:textSize="10sp"
                                app:buttonTint="@color/black" />

                            <CheckBox
                                android:id="@+id/text_display"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:layout_weight="1"
                                android:text="Display Text"
                                android:textColor="@color/black"
                                android:textSize="10sp"
                                android:visibility="gone"
                                app:buttonTint="@color/black" />

                            <CheckBox
                                android:id="@+id/business_rule"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:layout_weight="1"
                                android:text="Business Rules"
                                android:textColor="@color/black"
                                android:textSize="10sp"
                                android:visibility="gone"
                                app:buttonTint="@color/black" />

                        </LinearLayout>


                        <!--        <LinearLayout-->
                        <!--            android:layout_width="match_parent"-->
                        <!--            android:layout_height="wrap_content"-->
                        <!--            android:orientation="horizontal">-->

                        <!--          <CheckBox-->
                        <!--              android:id="@+id/camera"-->
                        <!--              android:layout_weight="1"-->
                        <!--              android:layout_width="wrap_content"-->
                        <!--              android:layout_height="wrap_content"-->
                        <!--              android:layout_marginTop="5dp"-->
                        <!--              app:buttonTint="@color/black"-->
                        <!--              android:textColor="@color/black"-->
                        <!--              android:text="Camera"/>-->


                        <!--          <CheckBox-->
                        <!--              android:id="@+id/onlyCamera"-->
                        <!--              android:layout_weight="1"-->
                        <!--              android:layout_width="wrap_content"-->
                        <!--              android:layout_height="wrap_content"-->
                        <!--              android:layout_marginTop="5dp"-->
                        <!--              android:textColor="@color/black"-->
                        <!--              app:buttonTint="@color/black"-->
                        <!--              android:text="Only Camera"/>-->

                        <!--          <CheckBox-->
                        <!--              android:id="@+id/debug"-->
                        <!--              android:layout_weight="1"-->
                        <!--              android:layout_width="wrap_content"-->
                        <!--              android:layout_height="wrap_content"-->
                        <!--              android:layout_marginTop="5dp"-->
                        <!--              android:textColor="@color/black"-->
                        <!--              app:buttonTint="@color/black"-->
                        <!--              android:visibility="gone"-->
                        <!--              android:text="Debug Mode"/>-->
                        <!--        </LinearLayout>-->


                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Camera Direction"
                            android:textColor="@color/black" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/list_bg"
                            android:padding="1dp">

                            <Spinner
                                android:id="@+id/spinner2"
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:prompt="@string/interval_prompt" />
                        </LinearLayout>

                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/bot_lay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">


                        <Button
                            android:id="@+id/loginbtn"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/btn_login_selector"
                            android:elevation="10dp"
                            android:gravity="center"
                            android:text="Go"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/edit_screen"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/btn_login_selector"
                            android:elevation="10dp"
                            android:gravity="center"
                            android:text="Edit"
                            android:textAllCaps="false"
                            android:textAppearance="@android:style/TextAppearance.Medium"
                            android:textColor="@color/white"
                            android:visibility="gone" />


                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bot_lay2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ProgressBar
                            android:id="@+id/progressSignOut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/logOut"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/btn_login_selector"
                            android:elevation="10dp"
                            android:gravity="center"
                            android:text="Sign out"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="16sp" />


                    </LinearLayout>

                </LinearLayout>
            </RelativeLayout>
        </RelativeLayout>

    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainSelectedScreenLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <!-- Waiting overlay: fullscreen, shown while loading ads -->
    <ImageView
        android:id="@+id/waitingLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@mipmap/app_icon"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/loadingBar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/tvAccent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Zero-size placeholder: Java holds reference but never renders -->
    <ImageView
        android:id="@+id/loadingLogo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@mipmap/logo1"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Two-panel wrapper -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Left: scrollable config form -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <RelativeLayout
                android:id="@+id/loginrootlayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Required by Java findViews(), kept at zero size -->
                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/topAppBar"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="@null" />

                <ImageView
                    android:id="@+id/picture"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@mipmap/picture"
                    android:visibility="gone" />

                <!-- Form content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="48dp"
                    android:paddingEnd="40dp"
                    android:paddingTop="36dp"
                    android:paddingBottom="40dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="28dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Screen Configuration"
                        android:textColor="@color/tvTextPrimary"
                        android:textSize="28sp" />

                    <!-- Orientation -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.06"
                        android:text="SCREEN ORIENTATION"
                        android:textAllCaps="true"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="11sp" />

                    <Spinner
                        android:id="@+id/spinner1"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="24dp"
                        android:background="@drawable/bg_tv_spinner"
                        android:entries="@array/screen_arrays"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:prompt="@string/screen_prompt"
                        android:theme="@style/ThemeOverlay.AppCompat.Dark" />

                    <!-- Screen ID -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.06"
                        android:text="SCREEN ID"
                        android:textAllCaps="true"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="11sp" />

                    <Spinner
                        android:id="@+id/spinnerID"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="24dp"
                        android:background="@drawable/bg_tv_spinner"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:prompt="@string/screen_prompt"
                        android:theme="@style/ThemeOverlay.AppCompat.Dark" />

                    <!-- Options -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:background="@drawable/bg_tv_card"
                        android:orientation="horizontal"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <CheckBox
                            android:id="@+id/rememberMeCh"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Remember Me"
                            android:textColor="@color/tvTextPrimary"
                            android:textSize="14sp"
                            app:buttonTint="@color/tvAccent" />

                        <CheckBox
                            android:id="@+id/text_display"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Display Text"
                            android:textColor="@color/tvTextPrimary"
                            android:textSize="14sp"
                            app:buttonTint="@color/tvAccent" />

                        <CheckBox
                            android:id="@+id/business_rule"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Business Rules"
                            android:textColor="@color/tvTextPrimary"
                            android:textSize="14sp"
                            app:buttonTint="@color/tvAccent" />

                    </LinearLayout>

                    <!-- Refresh Interval -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.06"
                        android:text="DATA REFRESH INTERVAL"
                        android:textAllCaps="true"
                        android:textColor="@color/tvTextSecondary"
                        android:textSize="11sp" />

                    <Spinner
                        android:id="@+id/spinner2"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="32dp"
                        android:background="@drawable/bg_tv_spinner"
                        android:entries="@array/interval_arrays"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:prompt="@string/interval_prompt"
                        android:theme="@style/ThemeOverlay.AppCompat.Dark" />

                    <!-- Primary action -->
                    <LinearLayout
                        android:id="@+id/bot_lay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/loginbtn"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_tv_button"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"
                            android:text="PLAY"
                            android:textAllCaps="true"
                            android:textColor="@color/tvTextPrimary"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/edit_screen"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_tv_button_secondary"
                            android:text="Edit"
                            android:textAllCaps="false"
                            android:textColor="@color/tvTextPrimary"
                            android:textSize="15sp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Secondary action -->
                    <LinearLayout
                        android:id="@+id/bot_lay2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <ProgressBar
                            android:id="@+id/progressSignOut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/tvAccent"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/logOut"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_tv_button_secondary"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.06"
                            android:text="SIGN OUT"
                            android:textAllCaps="true"
                            android:textColor="@color/tvTextSecondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>
            </RelativeLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/tvDivider" />

        <!-- Right: branding panel -->
        <LinearLayout
            android:id="@+id/logosLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/tvSurface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp">

            <ImageView
                android:id="@+id/ads_info"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end"
                android:layout_marginBottom="32dp"
                android:background="@drawable/baseline_info_24"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/Logo"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:contentDescription="Logo"
                android:scaleType="fitCenter"
                android:src="@mipmap/logo1" />

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_marginTop="24dp"
                android:contentDescription="Logo"
                android:scaleType="fitCenter"
                android:src="@mipmap/picture" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.12"
                android:text="DIGITAL SIGNAGE"
                android:textAllCaps="true"
                android:textColor="@color/tvTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

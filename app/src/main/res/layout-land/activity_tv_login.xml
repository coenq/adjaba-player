<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Left: QR code panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/tvSurface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="48dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/tvTextSecondary"
                android:textSize="18sp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/qr_code_image"
                android:layout_width="310dp"
                android:layout_height="310dp"
                android:background="@android:color/white"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_qr_url"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:textColor="@color/tvTextSecondary"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/tvDivider" />

        <!-- Right: code + instructions panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="72dp"
            android:paddingEnd="72dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.12"
                android:text="SIGN IN WITH TV CODE"
                android:textAllCaps="true"
                android:textColor="@color/tvTextSecondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_user_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.25"
                android:textColor="@color/tvTextPrimary"
                android:textSize="56sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="Scan the QR or visit adjaba.in/tv\nand enter this code"
                android:textColor="@color/tvTextSecondary"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tv_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:fontFamily="monospace"
                android:textColor="@color/tvTextHint"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_back_to_login"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:background="@drawable/bg_tv_button_secondary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:nextFocusUp="@+id/btn_back_to_login"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                android:text="Back to Normal Login"
                android:textColor="@color/tvTextPrimary"
                android:textSize="16sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tvBg">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Left: branding panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#000000"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="48dp">

            <ImageView
                android:id="@+id/Logo"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:contentDescription="Logo"
                android:scaleType="fitCenter"
                android:src="@drawable/adjaba_logo_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.16"
                android:text="DIGITAL SIGNAGE"
                android:textAllCaps="true"
                android:textColor="@color/tvTextSecondary"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/tvDivider" />

        <!-- Right: form panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="72dp"
            android:paddingEnd="72dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Welcome Back"
                android:textColor="@color/tvTextPrimary"
                android:textSize="36sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="40dp"
                android:fontFamily="sans-serif-light"
                android:text="Sign in to continue"
                android:textColor="@color/tvTextSecondary"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edt_email"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_tv_input"
                android:fontFamily="sans-serif-light"
                android:hint="Email address"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:nextFocusDown="@+id/edt_password"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/tvTextPrimary"
                android:textColorHint="@color/tvTextHint"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edt_password"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_tv_input"
                android:fontFamily="sans-serif-light"
                android:hint="Password"
                android:inputType="textPassword"
                android:maxLines="1"
                android:nextFocusDown="@+id/rememberMeCheckBox"
                android:nextFocusUp="@+id/edt_email"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/tvTextPrimary"
                android:textColorHint="@color/tvTextHint"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/rememberMeCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:nextFocusDown="@+id/btn_login"
                android:nextFocusUp="@+id/edt_password"
                android:text="Remember Me"
                android:textColor="@color/tvTextSecondary"
                android:textSize="15sp"
                app:buttonTint="@color/tvAccent" />

            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_tv_button"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:nextFocusDown="@+id/btn_tv_code"
                android:nextFocusUp="@+id/rememberMeCheckBox"
                android:text="SIGN IN"
                android:textAllCaps="true"
                android:textColor="@color/tvTextPrimary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn_tv_code"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_tv_button_secondary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:nextFocusUp="@+id/btn_login"
                android:text="Sign in with TV Code"
                android:textColor="@color/tvTextPrimary"
                android:textSize="16sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Loading overlay -->
    <ProgressBar
        android:id="@+id/progressBarLogin"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/tvAccent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

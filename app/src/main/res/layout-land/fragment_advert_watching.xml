<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape variant: weatherLayout=ConstraintLayout, newsLayout=FrameLayout -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainConstLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView android:id="@+id/waitingLogo"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:src="@mipmap/app_icon"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

    <ImageView android:id="@+id/adImageView"
        android:layout_width="0dp" android:layout_height="0dp"
        android:scaleType="centerCrop" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.exoplayer2.ui.PlayerView android:id="@+id/adPlayerView"
        android:layout_width="0dp" android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fill" app:use_controller="false" />

    <!-- ── WEATHER SLIDE (landscape): left=clock, right=temp, bottom=metrics ── -->
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/weatherLayout"
        android:layout_width="0dp" android:layout_height="0dp"
        android:background="@drawable/bg_weather_slide" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.Guideline android:id="@+id/v_center"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" app:layout_constraintGuide_percent="0.50" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/h_metrics"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" app:layout_constraintGuide_percent="0.78" />

        <LinearLayout android:id="@+id/location_row"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginStart="@dimen/slide_padding" android:layout_marginTop="@dimen/slide_padding"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/v_center"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView android:layout_width="@dimen/weather_metric_icon_size"
                android:layout_height="@dimen/weather_metric_icon_size"
                android:src="@drawable/baseline_location_pin_24" />
            <TextView android:id="@+id/weatherLoc"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="6dp" android:text="London" android:textColor="#6EA8D4"
                android:textSize="@dimen/text_location" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <TextView android:id="@+id/timeNow"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/slide_padding" android:layout_marginEnd="8dp"
            android:text="15:05" android:textColor="@color/white"
            android:textSize="@dimen/text_time" android:textStyle="bold"
            android:gravity="center" android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/v_center"
            app:layout_constraintTop_toBottomOf="@id/location_row" app:layout_constraintBottom_toTopOf="@id/h_metrics" />

        <View android:id="@+id/v_divider"
            android:layout_width="1dp" android:layout_height="0dp"
            android:background="#33FFFFFF" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
            app:layout_constraintStart_toStartOf="@id/v_center"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/h_metrics" />

        <LinearLayout android:id="@+id/temp_block"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginStart="8dp" android:layout_marginEnd="@dimen/slide_padding"
            app:layout_constraintStart_toEndOf="@id/v_center" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/h_metrics">
            <ImageView android:id="@+id/currentWeatherImg"
                android:layout_width="@dimen/weather_icon_size" android:layout_height="@dimen/weather_icon_size"
                android:layout_marginEnd="8dp" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:id="@+id/weatherTemp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="24°C" android:textColor="@color/white"
                    android:textSize="@dimen/text_temp" android:textStyle="bold" android:includeFontPadding="false" />
                <TextView android:id="@+id/currentStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="Sunny"
                    android:textColor="#7BA3CC" android:textSize="@dimen/text_condition" />
            </LinearLayout>
        </LinearLayout>

        <View android:id="@+id/h_divider"
            android:layout_width="0dp" android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="@dimen/slide_padding" android:layout_marginEnd="@dimen/slide_padding"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/h_metrics" />

        <LinearLayout android:id="@+id/metrics_bar"
            android:layout_width="0dp" android:layout_height="0dp"
            android:orientation="horizontal" android:gravity="center"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/h_divider" app:layout_constraintBottom_toBottomOf="parent">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size" android:src="@drawable/wind" />
                <TextView android:id="@+id/windW"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="32" android:textColor="@color/white"
                    android:textSize="@dimen/text_metrics" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="km/h" android:textColor="#546E7A" android:textSize="@dimen/text_label" />
            </LinearLayout>
            <View android:layout_width="1dp" android:layout_height="@dimen/metric_divider_height" android:background="#33FFFFFF" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size" android:src="@drawable/humidity" />
                <TextView android:id="@+id/hamudity"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="60" android:textColor="@color/white"
                    android:textSize="@dimen/text_metrics" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="%" android:textColor="#546E7A" android:textSize="@dimen/text_label" />
            </LinearLayout>
            <View android:layout_width="1dp" android:layout_height="@dimen/metric_divider_height" android:background="#33FFFFFF" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <ImageView android:layout_width="@dimen/weather_metric_icon_size"
                    android:layout_height="@dimen/weather_metric_icon_size" android:src="@drawable/umbrella" />
                <TextView android:id="@+id/rain"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="5" android:textColor="@color/white"
                    android:textSize="@dimen/text_metrics" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="mm" android:textColor="#546E7A" android:textSize="@dimen/text_label" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── NEWS SLIDE (landscape): left=image+headline, right=description ── -->
    <FrameLayout android:id="@+id/newsLayout"
        android:layout_width="0dp" android:layout_height="0dp"
        android:background="#0D1117" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">

        <com.facebook.shimmer.ShimmerFrameLayout android:id="@+id/shimmer"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone">
            <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#1A202C" />
        </com.facebook.shimmer.ShimmerFrameLayout>

        <LinearLayout android:id="@+id/newsFrame"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Left: image + badge + headline -->
            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageView android:id="@+id/news_img"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:scaleType="centerCrop" android:src="@mipmap/background_port" />
                <View android:id="@+id/header_background"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:layout_gravity="bottom"
                    android:background="@drawable/gradient_news_overlay" />
                <TextView android:id="@+id/newsTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="top|start" android:layout_margin="16dp"
                    android:background="@drawable/bg_news_badge"
                    android:letterSpacing="0.12"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:text="NEWS" android:textColor="@color/white"
                    android:textSize="@dimen/text_news_label" android:textStyle="bold" />
                <TextView android:id="@+id/main_header"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:ellipsize="end" android:maxLines="2"
                    android:lineSpacingMultiplier="1.15"
                    android:paddingStart="@dimen/news_text_padding" android:paddingEnd="@dimen/news_text_padding"
                    android:paddingBottom="@dimen/news_text_padding"
                    android:text="Breaking news headline"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_news_headline" android:textStyle="bold" />
            </FrameLayout>

            <!-- Right: description -->
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:background="#13182B"
                android:gravity="center_vertical" android:orientation="vertical"
                android:paddingStart="@dimen/news_text_padding" android:paddingEnd="@dimen/news_text_padding"
                android:paddingTop="24dp" android:paddingBottom="24dp">
                <TextView android:id="@+id/news_details"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:ellipsize="end" android:maxLines="6"
                    android:lineSpacingMultiplier="1.3"
                    android:text="News description" android:textColor="#D0D8E8"
                    android:textSize="@dimen/text_news_desc" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <ImageView android:id="@+id/qrCodeImage"
        android:layout_width="0dp" android:layout_height="0dp"
        android:layout_margin="5dp" android:adjustViewBounds="true"
        android:contentDescription="QR Code" android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintVertical_bias="0.95" />

    <ImageView android:id="@+id/logoImage"
        android:layout_width="100dp" android:layout_height="100dp"
        android:src="@drawable/final_logo" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" />

    <TextView android:id="@+id/displayText"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_margin="20dp" android:ellipsize="marquee"
        android:focusable="true" android:focusableInTouchMode="true"
        android:gravity="center" android:marqueeRepeatLimit="marquee_forever"
        android:scrollHorizontally="true" android:singleLine="true"
        android:text="Advert is Here" android:textColor="@color/white"
        android:textSize="19sp" android:textStyle="bold" android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar android:id="@+id/loadBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

    <TextView android:id="@+id/progressText"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Updating..." android:textColor="@color/black"
        android:textSize="25sp" android:textStyle="bold" android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loadBar" />

</androidx.constraintlayout.widget.ConstraintLayout>

